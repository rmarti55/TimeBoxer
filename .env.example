# Supabase — Project Settings → API (anon key only; never commit service_role)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# After creating the project:
# 1. Authentication → Providers → Email: enable Magic link (and optional SMTP).
# 2. Authentication → URL configuration → Redirect URLs:
#    - http://localhost:3000/auth/callback
#    - https://YOUR_PRODUCTION_DOMAIN/auth/callback
# 3. SQL Editor: run supabase/migrations/001_timebox_sessions.sql (or use Supabase CLI).
